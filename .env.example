# Copia este archivo a .env y completa valores reales.
# No comitear .env.

# Proveedor LLM para el agente jugador (openai, anthropic, deepseek)
LLM_PROVIDER=deepseek

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Narrador nocturno — modelo separado (opcional, si no se pone usa el del agente)
# NARRADOR_LLM_PROVIDER=anthropic
# NARRADOR_MODEL=claude-haiku-4-5-20251001
# NARRADOR_API_KEY=

# Logging/paths (si necesitas override)
MUNDO_DIR=/gonzalo/mundo
DF_DIR=/opt/df
DF_CMD=./dfhack
APP_TZ=America/Santiago

# Agente jugador: arranque automático (0=manual, 1=auto)
AGENT_AUTOSTART=0

# Stream a YouTube Live (0=off, 1=on)
STREAM_ENABLED=0
STREAM_URL=rtmp://a.rtmp.youtube.com/live2
STREAM_KEY=

# Ghost (blog — archivo de crónicas)
GHOST_URL=http://135.181.148.23
GHOST_ADMIN_API_KEY=

# Telegram (canal de crónicas + futuro bot interactivo)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Twitter/X (extracto + link al blog)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Resend (newsletter por email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_AUDIENCE_ID=
