# Copia este archivo a .env y completa valores reales.
# No comitear .env.

# Proveedor LLM (elige uno)
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Logging/paths (si necesitas override)
MUNDO_DIR=/gonzalo/mundo
DF_DIR=/opt/df
DF_CMD=./dwarfort
APP_TZ=America/Santiago
